# ── Supabase ──────────────────────────────────────────────────────────────
# Crie o projeto em https://supabase.com e rode supabase/migrations/0001_init.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOMENTE no servidor (cron de expurgo). Nunca expor ao cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ── Login único da equipe ───────────────────────────────────────────────────
# E-mail/senha da conta compartilhada criada no Supabase Auth.
TEAM_EMAIL=
TEAM_PASSWORD=

# ── OCR / extração da ficha de parto ────────────────────────────────────────
# SEM IA. A extração é 100% no dispositivo:
#   PDF com texto  → pdf.js extrai o texto → regex (parser por âncoras).
#   PDF imagem     → pdf.js rasteriza a página → Tesseract.js (por) → regex.
# Não há chave/API: nada de dado do paciente sai do navegador.

# ── Cron de expurgo (7 dias após alta) ──────────────────────────────────────
# Segredo para proteger a rota /api/cron/purge (Vercel Cron envia no header).
CRON_SECRET=
